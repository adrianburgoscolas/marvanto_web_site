---
interface Props {
  title: string;
  lastUpdated: string;
  intro: string;
}

const { title, lastUpdated, intro } = Astro.props;
---

<article class="legal-prose mx-auto max-w-3xl">
  <header class="mb-10 border-b border-white/10 pb-8">
    <h1 class="text-3xl font-extrabold tracking-tight text-white md:text-4xl">{title}</h1>
    <p class="mt-3 text-sm text-marvanto-muted">
      <strong class="text-white/80">Última actualización:</strong> {lastUpdated}
    </p>
    <p class="mt-6 text-base leading-relaxed text-white/75">{intro}</p>
  </header>
  <div class="legal-prose space-y-10">
    <slot />
  </div>
</article>
