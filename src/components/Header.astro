---
import TopBar from "./TopBar.astro";
import Logo from "./Logo.astro";

const currentPath = Astro.url.pathname;
const navLinks = [
  { href: "/", label: "Inicio" },
  { href: "/#categorias", label: "Servicios" },
  { href: "/contacto", label: "Contacto" },
];
---

<TopBar />

<header
  class="sticky top-0 z-50 border-b border-white/5 bg-marvanto-bg/30 backdrop-blur-lg"
>
  <div
    class="mx-auto flex h-16 max-w-7xl items-center justify-between px-4 md:h-[4.5rem] md:px-8 lg:px-12"
  >
    <button
      type="button"
      id="menu-toggle"
      class="flex h-11 w-11 items-center justify-center rounded-xl text-white transition-colors hover:bg-white/10 md:hidden"
      aria-expanded="false"
      aria-controls="mobile-menu"
      aria-label="Abrir menú de navegación"
    >
      <svg
        width="24"
        height="24"
        viewBox="0 0 24 24"
        fill="none"
        aria-hidden="true"
      >
        <path
          id="menu-icon-open"
          d="M3 6H21M3 12H21M3 18H21"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
        ></path>
        <path
          id="menu-icon-close"
          class="hidden"
          d="M6 6L18 18M18 6L6 18"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
        ></path>
      </svg>
    </button>

    <Logo />

    <nav
      class="hidden items-center gap-1 md:flex"
      aria-label="Navegación principal"
    >
      {
        navLinks.map(({ href, label }) => (
          <a
            href={href}
            class:list={[
              "rounded-lg px-4 py-2 text-sm font-medium transition-all hover:bg-white/5 hover:text-white",
              (href === "/" && currentPath === "/") ||
              (href.includes("contacto") && currentPath === "/contacto")
                ? "text-marvanto-accent"
                : "text-white/75",
            ]}
          >
            {label}
          </a>
        ))
      }
      <a
        href="/contacto"
        class="ml-3 rounded-full bg-marvanto-accent px-6 py-2.5 text-sm font-semibold text-white shadow-lg shadow-marvanto-accent/30 transition-all duration-300 hover:scale-105 hover:bg-marvanto-accent-hover hover:shadow-marvanto-accent/40"
      >
        Saber Más
      </a>
    </nav>

    <a
      href="/contacto"
      class="rounded-full bg-marvanto-accent/20 px-4 py-2 text-xs font-bold text-marvanto-accent ring-1 ring-marvanto-accent/30 md:hidden"
    >
      Contacto
    </a>
  </div>

  <nav
    id="mobile-menu"
    class="hidden border-t border-white/5 bg-marvanto-bg/95 px-4 py-4 backdrop-blur-xl md:hidden"
    aria-label="Menú móvil"
  >
    <ul class="flex flex-col gap-1">
      {
        navLinks.map(({ href, label }) => (
          <li>
            <a
              href={href}
              class="block rounded-xl px-4 py-3 text-base font-medium text-white/90 transition-colors hover:bg-white/5"
            >
              {label}
            </a>
          </li>
        ))
      }
      <li class="mt-2">
        <a
          href="/contacto"
          class="block rounded-full bg-marvanto-accent px-4 py-3 text-center text-base font-semibold text-white"
        >
          Saber Más
        </a>
      </li>
    </ul>
  </nav>
</header>

<script>
  const toggle = document.getElementById("menu-toggle");
  const menu = document.getElementById("mobile-menu");
  const iconOpen = document.getElementById("menu-icon-open");
  const iconClose = document.getElementById("menu-icon-close");

  toggle?.addEventListener("click", () => {
    const isOpen = menu?.classList.toggle("hidden") === false;
    toggle.setAttribute("aria-expanded", String(isOpen));
    toggle.setAttribute(
      "aria-label",
      isOpen ? "Cerrar menú de navegación" : "Abrir menú de navegación",
    );
    iconOpen?.classList.toggle("hidden", isOpen);
    iconClose?.classList.toggle("hidden", !isOpen);
  });
</script>
