---
---

<form class="space-y-5" method="POST" action="#" aria-label="Formulario de contacto">
  <div class="grid grid-cols-1 gap-5 sm:grid-cols-2">
    <div>
      <label for="nombre" class="mb-1.5 block text-sm font-medium text-marvanto-bg">
        Nombre <span class="text-marvanto-accent" aria-hidden="true">*</span>
      </label>
      <input
        type="text"
        id="nombre"
        name="nombre"
        required
        autocomplete="given-name"
        placeholder="Tu nombre"
        class="min-h-12 w-full rounded-xl border border-gray-200 bg-gray-50 px-4 text-marvanto-bg placeholder:text-marvanto-muted/50 transition-colors focus:border-marvanto-accent focus:bg-white focus:outline-none focus:ring-2 focus:ring-marvanto-accent/20"
      />
    </div>
    <div>
      <label for="apellido" class="mb-1.5 block text-sm font-medium text-marvanto-bg">
        Apellido <span class="text-marvanto-accent" aria-hidden="true">*</span>
      </label>
      <input
        type="text"
        id="apellido"
        name="apellido"
        required
        autocomplete="family-name"
        placeholder="Tu apellido"
        class="min-h-12 w-full rounded-xl border border-gray-200 bg-gray-50 px-4 text-marvanto-bg placeholder:text-marvanto-muted/50 transition-colors focus:border-marvanto-accent focus:bg-white focus:outline-none focus:ring-2 focus:ring-marvanto-accent/20"
      />
    </div>
  </div>

  <div>
    <label for="email" class="mb-1.5 block text-sm font-medium text-marvanto-bg">
      Email <span class="text-marvanto-accent" aria-hidden="true">*</span>
    </label>
    <input
      type="email"
      id="email"
      name="email"
      required
      autocomplete="email"
      placeholder="tu@email.com"
      class="min-h-12 w-full rounded-xl border border-gray-200 bg-gray-50 px-4 text-marvanto-bg placeholder:text-marvanto-muted/50 transition-colors focus:border-marvanto-accent focus:bg-white focus:outline-none focus:ring-2 focus:ring-marvanto-accent/20"
    />
  </div>

  <div>
    <label for="mensaje" class="mb-1.5 block text-sm font-medium text-marvanto-bg">
      Mensaje <span class="text-marvanto-accent" aria-hidden="true">*</span>
    </label>
    <textarea
      id="mensaje"
      name="mensaje"
      required
      rows="5"
      placeholder="Cuéntanos sobre tu proyecto..."
      class="w-full resize-y rounded-xl border border-gray-200 bg-gray-50 px-4 py-3 text-marvanto-bg placeholder:text-marvanto-muted/50 transition-colors focus:border-marvanto-accent focus:bg-white focus:outline-none focus:ring-2 focus:ring-marvanto-accent/20"
    ></textarea>
  </div>

  <button
    type="submit"
    class="min-h-12 w-full rounded-xl bg-marvanto-bg px-8 py-3 text-sm font-semibold text-white shadow-lg shadow-marvanto-bg/20 transition-all duration-300 hover:bg-marvanto-accent hover:shadow-marvanto-accent/30 focus:outline-none focus:ring-2 focus:ring-marvanto-accent focus:ring-offset-2"
  >
    Enviar mensaje
  </button>
</form>
