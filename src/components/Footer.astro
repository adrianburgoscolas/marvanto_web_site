      <!-- </div> -->
    </div>

    <div
      class="mt-12 flex flex-col items-center justify-between gap-4 border-t border-white/5 pt-8 sm:flex-row"
    >
      <p class="text-xs text-marvanto-muted">
        &copy; {currentYear} Marvanto Distribution. Todos los derechos reservados.
      </p>
      <div class="flex gap-6">
        <a
          href={withBase("/privacidad")}
          class="text-xs text-marvanto-muted transition-colors hover:text-white"
          >Privacidad</a
        >
        <a
          href={withBase("/terminos")}
          class="text-xs text-marvanto-muted transition-colors hover:text-white"
          >Términos</a
        >
      </div>
    </div>
  </div>
</footer>
