---

<footer class="relative border-t border-white/5 bg-marvanto-dark">
  <div
    class="pointer-events-none absolute inset-0 bg-gradient-to-t from-marvanto-accent/5 to-transparent"
    aria-hidden="true"
  >
  </div>
  <div class="relative mx-auto max-w-7xl px-4 py-16 md:px-8 lg:px-12">
    <div class="grid grid-cols-1 gap-12 md:grid-cols-2 lg:grid-cols-3">
      <div class="lg:col-span-1">
        <Logo />
        <p class="mt-4 text-sm leading-relaxed text-marvanto-muted">
          Su socio de confianza en distribución global. Conectamos oportunidades
          con resultados.
        </p>
      </div>

      <div>
        <h2
          class="mb-4 text-xs font-bold tracking-widest text-marvanto-muted uppercase"
        >
          Contacto
        </h2>
        <address class="space-y-3 not-italic">
          <p>
            <Telf slot="telef" />
          </p>
          <p>
            <Email slot="email" />
          </p>
          <Address slot="address" />
        </address>
      </div>

      <div>
        <h2
          class="mb-4 text-xs font-bold tracking-widest text-marvanto-muted uppercase"
        >
          Mapa del sitio
        </h2>
        <ul class="space-y-2">
          {
            siteMap.map(({ href, label }) => (
              <li>
                <a
                  href={href}
                  class="text-sm text-white/80 transition-colors hover:text-marvanto-accent"
                >
                  {label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- <div> -->
      <!--   <h2 -->
