import Telf from "./Telf.astro";
import Address from "./Address.astro";
import Email from "./Email.astro";
import Logo from "./Logo.astro";
import { withBase } from "../utils/paths";

const currentYear = new Date().getFullYear();

const siteMap = [
  { href: withBase("/"), label: "Inicio" },
  { href: withBase("/#productos"), label: "Catálogo" },
  { href: withBase("/#servicios"), label: "Servicios" },
  { href: withBase("/contacto"), label: "Contacto" },
  { href: withBase("/terminos"), label: "Términos" },
  { href: withBase("/privacidad"), label: "Privacidad" },
];

