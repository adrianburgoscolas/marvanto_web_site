---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  align?: "left" | "center";
  light?: boolean;
}

const { eyebrow, title, description, align = "left", light = false } = Astro.props;
---

<div class:list={[align === "center" && "text-center", "mb-10 md:mb-14"]}>
  {
    eyebrow && (
      <p
        class:list={[
          "mb-3 text-sm font-semibold tracking-widest uppercase",
          light ? "text-marvanto-accent" : "text-marvanto-accent",
        ]}
      >
        {eyebrow}
      </p>
    )
  }
  <h2
    class:list={[
      "text-2xl font-extrabold tracking-tight md:text-4xl lg:text-[2.75rem] lg:leading-tight",
      light ? "text-marvanto-bg" : "text-white",
      align === "center" && "mx-auto max-w-3xl",
    ]}
  >
    {title}
  </h2>
  {
    description && (
      <p
        class:list={[
          "mt-4 max-w-2xl text-base leading-relaxed md:text-lg",
          light ? "text-marvanto-muted" : "text-white/70",
          align === "center" && "mx-auto",
        ]}
      >
        {description}
      </p>
    )
  }
</div>
