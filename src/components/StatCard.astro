---
interface Props {
  value: string;
  suffix?: string;
  label: string;
}

const { value, suffix = "+", label } = Astro.props;
---

<div class="group relative overflow-hidden rounded-2xl glass p-6 text-center transition-all duration-300 hover:border-marvanto-accent/30 hover:bg-white/10 md:p-8">
  <div class="pointer-events-none absolute -top-8 -right-8 h-24 w-24 rounded-full bg-marvanto-accent/10 blur-2xl transition-all group-hover:bg-marvanto-accent/20" />
  <p class="text-4xl font-extrabold text-white md:text-5xl">
    <span class="stat-value" data-target={value}>0</span>{suffix}
  </p>
  <p class="mt-2 text-sm font-medium text-marvanto-muted">{label}</p>
</div>
