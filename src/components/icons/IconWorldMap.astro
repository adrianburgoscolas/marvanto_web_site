---
import { withBase } from "../../utils/paths";

interface Props {
  class?: string;
}

const { class: className = "h-full w-full" } = Astro.props;
---

<img
  src={withBase("/assets/svg/icon-world-map.svg")}
  alt=""
  class:list={[" object-cover", className]}
  aria-hidden="true"
  loading="lazy"
/>
